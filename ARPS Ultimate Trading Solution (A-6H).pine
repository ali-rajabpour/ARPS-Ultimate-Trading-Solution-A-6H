//------------------------- Stochastic RSI -----------------------------//
ShowStochRSI = input(true, title="Show Stochastic RSI")

StochRSIsmoothK = 1
StochRSIsmoothD = 1
StochRSIlengthRSI = 100
StochRSIlengthStoch = 100
StochRSIsrc = close

StochRSIrsi1 = rsi(StochRSIsrc, StochRSIlengthRSI)
StochRSIk = sma(stoch(StochRSIrsi1, StochRSIrsi1, StochRSIrsi1, StochRSIlengthStoch), StochRSIsmoothK)
StochRSId = sma(StochRSIk, StochRSIsmoothD)

// ***********************************************************************************
//------------------------- Money Flow Index -----------------------------//
Show_MFI = input(true, title="Show Money Flow Index")

//Inputs
MFIlength = 20
os = 20
ob = 80
//CurrentRes = true
//CustomRes = input("240", title="Custom Timeframe? Uncheck Box Above (E.g. 1M, 5D, 240 = 4Hours)")

//MFI Calc
//res = CurrentRes ? timeframe.period : CustomRes
rawMoneyFlow = hlc3 * volume

positiveMoneyFlow() =>
    a = 0.0
    a := hlc3 > hlc3[1] ? a + rawMoneyFlow : a
    a
negativeMoneyFlow() =>
    b = 0.0
    b := hlc3 < hlc3[1] ? b + rawMoneyFlow : b
    b

moneyFlowRatio = sma(positiveMoneyFlow(), MFIlength) / sma(negativeMoneyFlow(), MFIlength)

moneyFlowIndex = security(syminfo.tickerid, timeframe.period, 100 - 100 / (1 + moneyFlowRatio))

//OB/OS Identification
MFIoversold = Show_MFI and (moneyFlowIndex[1] > os[1] and moneyFlowIndex < os)
MFIoverbought = Show_MFI and (moneyFlowIndex[1] < ob[1] and moneyFlowIndex > ob)

// ***********************************************************************************
//------------------------- Squeeze Momentum Indicator -----------------------------//

Show_SQZMOM = input(true, title="Show Squeeze Momentum")

SQZMOMlength = 20		//BB Length
mult = 2.0		//BB MultFactor
lengthKC= 20		//KC Length
multKC = 1.5		//KC MultFactor
useTrueRange =  true		//Use TrueRange (KC)

// Calculate BB
source = close
basis = sma(source, SQZMOMlength)
dev = mult * stdev(source, SQZMOMlength)
upperBB = basis + dev
lowerBB = basis - dev

// Calculate KC
ma = sma(source, lengthKC)
range = useTrueRange ? tr : (high - low)
rangema = sma(range, lengthKC)
upperKC = ma + rangema * multKC
lowerKC = ma - rangema * multKC

sqzOn  = (lowerBB > lowerKC) and (upperBB < upperKC)
sqzOff = (lowerBB < lowerKC) and (upperBB > upperKC)
noSqz  = (sqzOn == false) and (sqzOff == false)

val = linreg(source  -  avg(avg(highest(high, lengthKC), lowest(low, lengthKC)),sma(close,lengthKC)), lengthKC,0)

// 10 = maroon/Go Long  |  12 = Green/Go Short  |  22 = red/ExitShort  |  11 = lime/Exit Long
sqz_position = iff( val > 0, iff( val > nz(val[1]), 11, 12), iff( val < nz(val[1]), 22, 10))

sqzGoLong = sqzOff and (sqz_position == 11) and (val < 51)
sqzGoShort = sqzOff and (sqz_position == 22) and (val > -51)
//sqzExitLong = sqzOff and (sqz_position == 11)
//sqzExitShort = sqzOff and (sqz_position == 22)

// ***********************************************************************************
//------------------- Fibonacci Resistance & Support Levels ------------------------//

Show_ResSup = input(true, title="Show Fibonacci Resistance & Support Levels")

use_monthly = true
months_in = 1		//Months for Monthly Basis (this is limited by max lookback at your resolution!)"
use_weekly = true
weeks_in = 2		//Weeks for Weekly Basis
use_daily = true
days_in = 7		//Days for Daily Basis
hold_intraday = true
connect_lines = false		//Connect Sup/Res Crosses with a Line?

zigzag(_price, _high, _low, _depth, _filter) =>
    _offset = max(floor(_depth / 2), 2)
    _deviation = highest(stdev(_price[_offset], 50) / nz(_price[_offset], 1), 100) * 
       (1 - _filter / 100)
    _window = int(na)
    _window := nz(_window[1]) + 1
    _long_enough = _window >= _depth
    _top = _high[_offset - 1] < nz(_high[_offset])
    _bottom = _low[_offset - 1] > nz(_low[_offset])
    _zz_candidate = (_top or _bottom) and _long_enough
    _last_extreme = _high[_offset]
    _last_extreme := nz(_last_extreme[1])
    if _top and _bottom
        if abs(_last_extreme - _high[_offset]) > abs(_last_extreme - _low[_offset])
            _bottom := false
            _bottom
        else
            _top := false
            _top
    _this_extreme = _top ? _high[_offset] : _bottom ? _low[_offset] : na
    _zz_found = _zz_candidate and _long_enough and 
       abs(_this_extreme - _last_extreme) / nz(_price[_offset], 1) > _deviation or 
       _high[_offset] >= highest(_high, _depth) or 
       _low[_offset] <= lowest(_low, _depth)
    if _zz_found
        _last_extreme := _this_extreme
        _window := 0
        _window
    _zigzag = _zz_found ? _this_extreme : na
    _zigzag


fib_source = "Monthly" //"Draw Fibonacci Levels For Which Basis Pair?", options=["None", "Monthly", "Weekly", "Daily", "Hourly", "Minutes"]
fib_invert = false


daysinweek = 7

months = months_in % 12
year_months = floor(months_in / 12) * 12  //*12 added after commenting out below
monthly_bars = (timeframe.ismonthly ? months_in : (timeframe.isintraday ? 1440 : 1) * 
   (year_months * 52 * daysinweek + months * 4 * daysinweek) / 
   (timeframe.isweekly ? daysinweek : 1)) / timeframe.multiplier
monthly_high = highest(high, min(5000, monthly_bars))
monthly_low = lowest(low, min(5000, monthly_bars))
//plot(n)
weeks = weeks_in % 52
year_weeks = floor(weeks_in / 52) * daysinweek
weekly_bars = (timeframe.isweekly ? weeks_in : (timeframe.isintraday ? 1440 : 1) * 
   (year_weeks * 52 * daysinweek + weeks * daysinweek) / 
   (timeframe.ismonthly ? 4 * daysinweek : 1)) / timeframe.multiplier
weekly_high = highest(high, min(5000, weekly_bars))
weekly_low = lowest(low, min(5000, weekly_bars))

days = timeframe.ismonthly ? max(days_in, 4 * daysinweek) : 
   timeframe.isweekly ? max(days_in, daysinweek) : days_in
daily_bars = (timeframe.isdaily ? days : (timeframe.isintraday ? 1440 : 1) * days / 
   ((timeframe.ismonthly ? 4 * daysinweek : 1) * 
   (timeframe.isweekly ? daysinweek : 1))) / timeframe.multiplier
daily_high = highest(high, min(5000, daily_bars))
daily_low = lowest(low, min(5000, daily_bars))

flat_monthly_high = high
flat_monthly_low = low
flat_weekly_high = high
flat_weekly_low = low
flat_daily_high = high
flat_daily_low = low

flat_monthly_high := change(dayofmonth) ? monthly_high : na(monthly_high) ? na : 
   nz(flat_monthly_high[1], na(monthly_high[1]) ? monthly_high : high)
flat_monthly_low := change(dayofmonth) ? monthly_low : na(monthly_low) ? na : 
   nz(flat_monthly_low[1], na(monthly_low[1]) ? monthly_low : low)
flat_weekly_high := change(dayofmonth) ? weekly_high : na(weekly_high) ? na : 
   nz(flat_weekly_high[1], na(weekly_high[1]) ? weekly_high : high)
flat_weekly_low := change(dayofmonth) ? weekly_low : na(weekly_low) ? na : 
   nz(flat_weekly_low[1], na(weekly_low[1]) ? weekly_low : low)
flat_daily_high := change(dayofmonth) ? daily_high : na(daily_high) ? na : 
   nz(flat_daily_high[1], na(daily_high[1]) ? daily_high : high)
flat_daily_low := change(dayofmonth) ? daily_low : 
   na(daily_low) ? na : nz(flat_daily_low[1], na(daily_low[1]) ? daily_low : low)

plot_monthly_high = hold_intraday ? flat_monthly_high : monthly_high
plot_monthly_low = hold_intraday ? flat_monthly_low : monthly_low
plot_weekly_high = hold_intraday ? flat_weekly_high : weekly_high
plot_weekly_low = hold_intraday ? flat_weekly_low : weekly_low
plot_daily_high = hold_intraday ? flat_daily_high : daily_high
plot_daily_low = hold_intraday ? flat_daily_low : daily_low

fhigh = float(na)
flow = float(na)

if fib_source != "None"
    fhigh := fib_source == "Monthly" ? plot_monthly_high : 
       fib_source == "Weekly" ? plot_weekly_high : 
       fib_source == "Daily" ? plot_daily_high : na
    flow := fib_source == "Monthly" ? plot_monthly_low : 
       fib_source == "Weekly" ? plot_weekly_low : 
       fib_source == "Daily" ? plot_daily_low : na
    flow

calc_fib(_max, _min, _dir) =>
    _diff = _max - _min
    _236 = _diff * 0.236 * (_dir ? -1 : 1) + (_dir ? _max : _min)
    _382 = _diff * 0.382 * (_dir ? -1 : 1) + (_dir ? _max : _min)
    _500 = _diff * 0.5 * (_dir ? -1 : 1) + (_dir ? _max : _min)
    _618 = _diff * 0.618 * (_dir ? -1 : 1) + (_dir ? _max : _min)
    _786 = _diff * 0.786 * (_dir ? -1 : 1) + (_dir ? _max : _min)
    _1618 = _diff * 1.618 * (_dir ? -1 : 1) + (_dir ? _max : _min)
    [_236, _382, _500, _618, _786, _1618]

[F236, F382, F500, F618, F786, F1618] = calc_fib(fhigh, flow, fib_invert)
p236 = plot(Show_ResSup ? F236 : na, color=color.red, editable=false)
p382 = plot(Show_ResSup ? F382 : na, color=color.yellow, editable=false)
p500 = plot(Show_ResSup ? F500 : na, color=color.lime, editable=false)
p618 = plot(Show_ResSup ? F618 : na, color=color.aqua, editable=false)
p786 = plot(Show_ResSup ? F786 : na, color=color.teal, editable=false)
p1618 = plot(Show_ResSup ? F1618 : na, color=color.blue, editable=false)

color_monthly_high = use_monthly ? color.gray : na
color_monthly_low = use_monthly ? color.gray : na
pMh = plot(Show_ResSup and use_monthly ? plot_monthly_high : high, style=plot.style_cross, color=color_monthly_high, linewidth=4, transp=65, join=connect_lines, editable=false)  //change plotted values for better autoscaling
pMl = plot(Show_ResSup and use_monthly ? plot_monthly_low : low, style=plot.style_cross, color=color_monthly_low, linewidth=4, transp=80, join=connect_lines, editable=false)

color_weekly_high = use_weekly ? color.red : na
color_weekly_low = use_weekly ? color.red : na
pwh = plot(Show_ResSup and use_weekly ? plot_weekly_high : high, style=plot.style_circles, color=color_weekly_high, linewidth=3, transp=65, join=connect_lines, editable=false)
pwl = plot(Show_ResSup and use_weekly ? plot_weekly_low : low, style=plot.style_circles, color=color_weekly_low, linewidth=3, transp=80, join=connect_lines, editable=false)

color_daily_high = use_daily ? color.blue : na
color_daily_low = use_daily ? color.blue : na
pdh = plot(Show_ResSup and use_daily ? plot_daily_high : high, style=plot.style_cross, color=color_daily_high, linewidth=3, transp=65, join=connect_lines, editable=false)
pdl = plot(Show_ResSup and use_daily ? plot_daily_low : low, style=plot.style_cross, color=color_daily_low, linewidth=3, transp=80, join=connect_lines, editable=false)

fphigh = fib_invert ? flow : fhigh
fplow = fib_invert ? fhigh : flow
phigh = plot(Show_ResSup ? fphigh : na, color=na, editable=false)
plow = plot(Show_ResSup ? fplow : na, color=na, editable=false)

// ***********************************************************************************
//------------------------------------ Wave trend ----------------------------------//

//Overbought level = 60 | Oversold Level = -60

Wave_Signals = input(true, title="Show WaveTrend Signals")

n1 = 4	//defval=10, "Channel Length", CryptoFace=9
n2 = 1	//defval=21, "Average Length", CryptoFace=12
 
ap = hlc3 
esa = ema(ap, n1)
d = ema(abs(ap - esa), n1)
ci = (ap - esa) / (0.015 * d)
tci = ema(ci, n2)
 
wt1 = tci
wt2 = sma(wt1,3)

WT_OS = (wt1 < -60) and (crossover(wt1, wt2))
WT_OB = (wt1 > 60) and (crossover(wt2, wt1))

