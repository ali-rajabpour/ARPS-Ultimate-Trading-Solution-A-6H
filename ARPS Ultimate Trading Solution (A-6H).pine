//plotshape(Candle_patterns ? bearE : na,  title= "Bearish Engulfing", color=color.red, style=shape.arrowdown, text="Bearish\nEngulfing", editable=false)

//Bullish Engulfing
//bullE=(close[2] < open[2] and close > open and close[2] < close and close[2] > open and open[2] < close and open[2] > open and low[2] > open )
//plotshape(Candle_patterns ? bullE : na, title= "Bullish Engulfing", location=location.belowbar, color=color.lime, style=shape.arrowup, text="Bullish\nEngulfling", editable=false)

//Bearish Dark Cloud Cover
//dcc=((close[2]>open[2])and(((close[2]+open[2])/2)>close)and(open>close)and(open>close[2])and(close>open[2])and((open-close)/(.001+(high-low))>0.6))
//plotshape(Candle_patterns ? dcc : na, title= "Bearish Dark Cloud Cover", color=color.red, style=shape.arrowdown, text="Bearish\nDark\nCloudCover", editable=false)

// ***********************************************************************************
//-------------------------------  Hull MA -----------------------------------------//

Hullength = 50
HullSrc = close
Show_Hull = input(true, title="Show Hull-T3 Lines & Signals")
hullma = wma(2*wma(HullSrc, Hullength/2)-wma(HullSrc, Hullength), round(sqrt(Hullength)))
plot(Show_Hull ? hullma : na, color = color.green, linewidth = 4, editable=false)

// ***********************************************************************************
//-------------------------------  Tillson MA --------------------------------------//

length1 = 20
a1 = 0.7

e1 = ema((high + low + 2 * close) / 4, length1)
e2 = ema(e1, length1)
e3 = ema(e2, length1)
e4 = ema(e3, length1)
e5 = ema(e4, length1)
e6 = ema(e5, length1)
c1 = -a1 * a1 * a1
c2 = 3 * a1 * a1 + 3 * a1 * a1 * a1
c3 = -6 * a1 * a1 - 3 * a1 - 3 * a1 * a1 * a1
c4 = 1 + 3 * a1 + a1 * a1 * a1 + 3 * a1 * a1
T3 = c1 * e6 + c2 * e5 + c3 * e4 + c4 * e3

col1 = T3 > T3[1]
col3 = T3 < T3[1]
plot(Show_Hull ? T3 : na, color=color.red, linewidth=4, title="T3", editable=false)

T3HullLE = (crossover(hullma, T3) and (wt2 < 25))
T3HullSE = (crossover(T3, hullma) and (wt2 > -25))
// ***********************************************************************************
//------------------------------ Price-info Label -----------------------------------//

Show_Price = input(true, title="Show Price-info Label")

stoploss_price_long = low - (2 * atr(30))
stoploss_price_short = high + (2 * atr(30))

if close > open and barstate.islast and Show_Price
	PriceLabel = label.new(bar_index, high, text="Stoploss Long= " + tostring(stoploss_price_long, '#.####') + "\nStoploss Short= " + tostring(stoploss_price_short, '#.####') + "\nWT= " + tostring(wt2, '#.##') + " (-64 -> 64)" + "\nSQZ MOM= " + tostring(val, '#.##') + " (-200 -> 200)" + "\nMFI= " + tostring(moneyFlowIndex, '#.##') + " (20 -> 80)" + "\nRSI= " + tostring(RsiValue14, '#.##') + " (20 -> 80)" ,style=label.style_labeldown, color=#a8dadc)
	label.set_textcolor(PriceLabel, textcolor=color.black)
	label.delete(PriceLabel[1])

if open > close  and barstate.islast and Show_Price
	PriceLabel = label.new(bar_index, low, text="Stoploss Long= " + tostring(stoploss_price_long, '#.####') + "\nStoploss Short= " + tostring(stoploss_price_short, '#.####') + "\nWT= " + tostring(wt2, '#.##') + " (-64 -> 64)" + "\nSQZ MOM= " + tostring(val, '#.##') + " (-200 -> 200)"  + "\nMFI= " + tostring(moneyFlowIndex, '#.##') + " (20 -> 80)" + "\nRSI= " + tostring(RsiValue14, '#.##') + " (20 -> 80)" , style=label.style_labelup, color=#a8dadc)
	label.set_textcolor(PriceLabel, textcolor=color.black)
	label.delete(PriceLabel[1])
	
// ***********************************************************************************
//---------------------------------- Conditions ------------------------------------//

LongConditions = T3HullLE or sqzGoLong or WT_OS or crossover(ZEMA_50_6h, ZEMA_200_6h) or crossover(ZEMA_50_12h, ZEMA_200_12h) or crossover(ZEMA_50_d, ZEMA_200_d) or crossover(Tenkan, Kijun) or crossover(ZEMA_13_6h, ZEMA_48_6h)

ShortConditions = T3HullSE or sqzGoShort or WT_OB or crossover(ZEMA_200_6h, ZEMA_50_6h) or crossover(ZEMA_200_12h, ZEMA_50_12h) or crossover(ZEMA_200_d, ZEMA_50_d) or crossover(Kijun, Tenkan) or crossover(ZEMA_48_6h, ZEMA_13_6h)

// ***********************************************************************************
//------------------------------------ Labels and Arrows --------------------------------------//
plot((Show_Hull and (T3HullLE or T3HullSE)) ? hullma : na, style = plot.style_cross, color=color.black, linewidth = 4, editable=false)
plot((ShowTenkanKijun and cross(Tenkan, Kijun)) ? Tenkan : na, style = plot.style_cross, color=color.black, linewidth = 4, editable=false)

OSCsCoefficient = 0.0
if open > 20000
	OSCsCoefficient := 0.1005
if open > 5000 and open < 20000
	OSCsCoefficient := 0.0201
if 300 < open and open < 5000
	OSCsCoefficient := 0.057
if 10 < open and open < 300
	OSCsCoefficient := 0.18
if open < 10
	OSCsCoefficient := 0.06


//EMAs Crosses
//EMA-6H
if ShowEMA_6h_Crosses and crossover(ZEMA_50_6h, ZEMA_200_6h)
	EMA_6H_Cross_up = label.new(bar_index, low - (0.0035 * low), text="ZEMA Cx\n50|200\n(6H)", style=label.style_labelup, color=#0CCD00)
	label.set_textcolor(EMA_6H_Cross_up, textcolor=color.white)
	
if ShowEMA_6h_Crosses and crossover(ZEMA_200_6h, ZEMA_50_6h)
	EMA_6H_Cross_down = label.new(bar_index, high + (0.0035 * high), text="ZEMA Cx\n200|50\n(6H)", style=label.style_labeldown, color=#FF0000)
	label.set_textcolor(EMA_6H_Cross_down, textcolor=color.white)

//EMA 13|48 at 6H
if ShowEMA_1348_Crosses and crossover(ZEMA_13_6h, ZEMA_48_6h)
	EMA_1348_Cross_up = label.new(bar_index, low - (0.0035 * low), text="ZEMA Cx\n13|48\n(6H)", style=label.style_labelup, color=#0CCD00)
	label.set_textcolor(EMA_1348_Cross_up, textcolor=color.white)
	
if ShowEMA_1348_Crosses and crossover(ZEMA_48_6h, ZEMA_13_6h)
	EMA_1348_Cross_down = label.new(bar_index, high + (0.0035 * high), text="ZEMA Cx\n48|13\n(6H)", style=label.style_labeldown, color=#FF0000)
	label.set_textcolor(EMA_1348_Cross_down, textcolor=color.white)

//EMA-12H
if ShowEMA_12h_Crosses and crossover(ZEMA_50_12h, ZEMA_200_12h)
	EMA_12h_Cross_up = label.new(bar_index, low -(0.0035 * low), text="ZEMA Cx\n50|200\n(12H)", style=label.style_labelup, color=#0CCD00)
	label.set_textcolor(EMA_12h_Cross_up, textcolor=color.white)
	
if ShowEMA_12h_Crosses and crossover(ZEMA_200_12h, ZEMA_50_12h)
	EMA_12h_Cross_down = label.new(bar_index, high + (0.0035 * high), text="ZEMA Cx\n200|50\n(12H)", style=label.style_labeldown, color=#FF0000)
	label.set_textcolor(EMA_12h_Cross_down, textcolor=color.white)

//EMA-D
if ShowEMA_d_Crosses and crossover(ZEMA_50_d, ZEMA_200_d)
	EMA_d_Cross_up = label.new(bar_index, low - (0.0035 * low), text="ZEMA Cx\n50|200\n(D)", style=label.style_labelup, color=#0CCD00)
	label.set_textcolor(EMA_d_Cross_up, textcolor=color.white)

	
if ShowEMA_d_Crosses and crossover(ZEMA_200_d, ZEMA_50_d)
	EMA_d_Cross_down = label.new(bar_index, high + (0.0035 * high), text="ZEMA Cx\n200|50\n(D)", style=label.style_labeldown, color=#FF0000)
	label.set_textcolor(EMA_d_Cross_down, textcolor=color.white)


//200 EMAs Oscillators
//6H	
if Show200EMAs and barstate.islast and ((close > (EMA1 + (EMA1 * 0.002))) and (open > (EMA1 + (EMA1 * 0.002))))
	PriceEmaPos1 = label.new(x=time, y=open + (open * OSCsCoefficient), xloc=xloc.bar_time, text="200EMA\n(6H)", style=label.style_arrowup, color=color.green)
	label.set_x(id=PriceEmaPos1, x=label.get_x(id=PriceEmaPos1) + 302400000)
	label.set_size(PriceEmaPos1, size.normal)
	label.delete(id=PriceEmaPos1[1])
if Show200EMAs and barstate.islast and ((close < (EMA1 - (EMA1 * 0.002))) and (open < (EMA1 - (EMA1 * 0.002))))
	PriceEmaPos1 = label.new(x=time, y=open + (open * OSCsCoefficient), xloc=xloc.bar_time, text="200EMA\n(6H)", style=label.style_arrowdown, color=color.red)
	label.set_x(id=PriceEmaPos1, x=label.get_x(id=PriceEmaPos1) + 302400000)
	label.set_size(PriceEmaPos1, size.normal)
	label.delete(id=PriceEmaPos1[1])
	
//12H - EMA
if Show200EMAs and barstate.islast and ((close > (EMA2 + (EMA2 * 0.002))) and (open > (EMA2 + (EMA2 * 0.002))))
	PriceEmaPos2 = label.new(x=time, y=open + (open * OSCsCoefficient), xloc=xloc.bar_time, text="200EMA\n(12H)", style=label.style_arrowup, color=color.green)
	label.set_x(id=PriceEmaPos2, x=label.get_x(id=PriceEmaPos2) + 367200000)
	label.set_size(PriceEmaPos2, size.normal)
	label.delete(id=PriceEmaPos2[1])
if Show200EMAs and barstate.islast and ((close < (EMA2 - (EMA2 * 0.002))) and (open < (EMA2 - (EMA2 * 0.002))))
	PriceEmaPos2 = label.new(x=time, y=open + (open * OSCsCoefficient), xloc=xloc.bar_time, text="200EMA\n(12H)", style=label.style_arrowdown, color=color.red)
	label.set_x(id=PriceEmaPos2, x=label.get_x(id=PriceEmaPos2) + 367200000)
	label.set_size(PriceEmaPos2, size.normal)
	label.delete(id=PriceEmaPos2[1])
	
//12H - ZEMA
if Show200EMAs and barstate.islast and ((close > (ZEMA_200_12h + (ZEMA_200_12h * 0.002))) and (open > (ZEMA_200_12h + (ZEMA_200_12h * 0.002))))
	PriceEmaPos3 = label.new(x=time, y=open + (open * OSCsCoefficient), xloc=xloc.bar_time, text="200ZEMA\n(12H)", style=label.style_arrowup, color=color.green)
	label.set_x(id=PriceEmaPos3, x=label.get_x(id=PriceEmaPos3) + 432000000)
	label.set_size(PriceEmaPos3, size.normal)
	label.delete(id=PriceEmaPos3[1])
if Show200EMAs and barstate.islast and ((close < (ZEMA_200_12h - (ZEMA_200_12h * 0.002))) and (open < (ZEMA_200_12h - (ZEMA_200_12h * 0.002))))
	PriceEmaPos3 = label.new(x=time, y=open + (open * OSCsCoefficient), xloc=xloc.bar_time, text="200ZEMA\n(12H)", style=label.style_arrowdown, color=color.red)
	label.set_x(id=PriceEmaPos3, x=label.get_x(id=PriceEmaPos3) + 432000000)
	label.set_size(PriceEmaPos3, size.normal)
	label.delete(id=PriceEmaPos3[1])
	
//D	
if Show200EMAs and barstate.islast and ((close > (EMA3 + (EMA3 * 0.002))) and (open > (EMA3 + (EMA3 * 0.002))))
	PriceEmaPos4 = label.new(x=time, y=open + (open * OSCsCoefficient), xloc=xloc.bar_time, text="200EMA\n(D)", style=label.style_arrowup, color=color.green)
	label.set_x(id=PriceEmaPos4, x=label.get_x(id=PriceEmaPos4) + 496800000)
	label.set_size(PriceEmaPos4, size.normal)
	label.delete(id=PriceEmaPos4[1])
if Show200EMAs and barstate.islast and ((close < (EMA3 - (EMA3 * 0.002))) and (open < (EMA3 - (EMA3 * 0.002))))
	PriceEmaPos4 = label.new(x=time, y=open + (open * OSCsCoefficient), xloc=xloc.bar_time, text="200EMA|\n(D)", style=label.style_arrowdown, color=color.red)
	label.set_x(id=PriceEmaPos4, x=label.get_x(id=PriceEmaPos4) + 496800000)
	label.set_size(PriceEmaPos4, size.normal)
	label.delete(id=PriceEmaPos4[1])	

//StochRSI
if ShowStochRSI and barstate.islast and StochRSId > 50
	StochRSI_Position = label.new(x=time, y=open, xloc=xloc.bar_time, text="StochRSI", style=label.style_arrowup, color=color.green)
	label.set_x(id=StochRSI_Position, x=label.get_x(id=StochRSI_Position) + 432000000)
	label.set_size(StochRSI_Position, size.normal)
	label.delete(id=StochRSI_Position[1])
	
if ShowStochRSI and barstate.islast and StochRSId < 50
	StochRSI_Position = label.new(x=time, y=open, xloc=xloc.bar_time, text="StochRSI", style=label.style_arrowdown, color=color.red)
	label.set_x(id=StochRSI_Position, x=label.get_x(id=StochRSI_Position) + 432000000)
	label.set_size(StochRSI_Position, size.normal)
	label.delete(id=StochRSI_Position[1])

//SQZ Mom
if Show_SQZMOM and sqzGoLong
	SqzMomLabel = label.new(bar_index, low - (0.0035 * low), text="SQZ MOM\nLE", style=label.style_labelup, color=#0CCD00)
	
if Show_SQZMOM and sqzGoShort
	SqzMomLabel = label.new(bar_index, high + (0.0035 * high), text="SQZ MOM\nSE", style=label.style_labeldown, color=#FF0000)
	label.set_textcolor(SqzMomLabel, textcolor=color.white)
	
//MFI
//Oscillators
//Long
if Show_MFI and barstate.islast and moneyFlowIndex > 51
	MFIchangeRate = label.new(x=time, y=open, xloc=xloc.bar_time, text="MFI", style=label.style_arrowup, color=color.green)
	label.set_x(id=MFIchangeRate, x=label.get_x(id=MFIchangeRate) + 367200000)
	label.set_size(MFIchangeRate, size.normal)
	label.delete(id=MFIchangeRate[1])
//Short	
if Show_MFI and barstate.islast and moneyFlowIndex < 49
	MFIchangeRate = label.new(x=time, y=open, xloc=xloc.bar_time, text="MFI", style=label.style_arrowdown, color=color.red)
	label.set_x(id=MFIchangeRate, x=label.get_x(id=MFIchangeRate) + 367200000)
	label.set_size(MFIchangeRate, size.normal)
	label.delete(id=MFIchangeRate[1])
	
//Positions:
//Overbought
if Show_MFI and MFIoverbought
	MfiLabel = label.new(bar_index, high + (0.003 * high), text="MFI OB\n(Exit Long)", style=label.style_labeldown, color=#d62828)
	label.set_textcolor(MfiLabel, textcolor=color.white)
	
//Oversold
if Show_MFI and MFIoversold
	MfiLabel = label.new(bar_index, low - (0.003 * low), text="MFI OS\n(Exit Short)", style=label.style_labelup, color=#007f5f)
	label.set_textcolor(MfiLabel, textcolor=color.white)
	
//RSI
//Overbought
if ShowRSI and RsiValue14 > 89
	RsiLabel = label.new(bar_index, high + (0.003 * high), text="RSI OB", style=label.style_labeldown, color=#d62828)
	label.set_textcolor(RsiLabel, textcolor=color.white)
	
//Oversold
if ShowRSI and RsiValue14 < 11
	RsiLabel = label.new(bar_index, low - (0.003 * low), text="RSI OS", style=label.style_labelup, color=#007f5f)
	label.set_textcolor(RsiLabel, textcolor=color.white)
	
	
//Wave Trend Oversize
//if Wave_Signals and wave_over_size and barstate.islast
//	label0 = label.new(bar_index, high + 100, style=label.style_flag, color=#ffbe0b)
//	label.delete(id=label0[1])

//Aligator
if barstate.islast and ShowAlligator and AlligatorState == 1
	alligator_state = label.new(x=time, y=open - (open * OSCsCoefficient), xloc=xloc.bar_time, text="🐊 Alligator is Hunting the Bulls 🐮\n(@6H)" , textalign=text.align_center, style=label.style_none, color=#f0f3fa)
	label.set_x(id=alligator_state, x=label.get_x(id=alligator_state) + 399600000)
	label.set_size(alligator_state, size.large)
	label.delete(id=alligator_state[1])
	
if barstate.islast and ShowAlligator and AlligatorState == -1
	alligator_state = label.new(x=time, y=open - (open * OSCsCoefficient), xloc=xloc.bar_time, text="🐊 Alligator is Hunting the Bears 🐻\n(@6H)" , textalign=text.align_center, style=label.style_none, color=#f0f3fa)
	label.set_x(id=alligator_state, x=label.get_x(id=alligator_state) + 399600000)
	label.set_size(alligator_state, size.large)
	label.delete(id=alligator_state[1])

if barstate.islast and ShowAlligator and (AlligatorState != -1) and (AlligatorState != 1)
	alligator_state = label.new(x=time, y=open - (open * OSCsCoefficient), xloc=xloc.bar_time, text="🐊 Alligator is Sleep 💤\n(@6H)" , textalign=text.align_center, style=label.style_none, color=#f0f3fa)
	label.set_x(id=alligator_state, x=label.get_x(id=alligator_state) + 399600000)
	label.set_size(alligator_state, size.large)
	label.delete(id=alligator_state[1])
	
//Copyright
if barstate.islast
	LegendBox = label.new(x=time, y=open - (open * 2 * OSCsCoefficient), xloc=xloc.bar_time, text="Ali Rajabpour-Sanati\nali.poursanati@gmail.com" , textalign=text.align_center, style=label.style_none, color=#f0f3fa)
	label.set_x(id=LegendBox, x=label.get_x(id=LegendBox) + 399600000)
	label.set_size(LegendBox, size.normal)
	label.delete(id=LegendBox[1])

//Long Positions

if T3HullLE and Show_Hull
	label1 = label.new(bar_index, low, text="T3-Hull LE", style=label.style_labelup, color=#0CCD00)
	
if WT_OS and Wave_Signals
	label1 = label.new(bar_index, low, text="WT LE", style=label.style_labelup, color=#0CCD00)

if ShowTenkanKijunLables and crossover(Tenkan, Kijun)
	labelTenkan = label.new(bar_index, low, text="Tenkan|Kijun\nCx", style=label.style_labelup, color=#0CCD00)


//Short Positions
	
if T3HullSE and Show_Hull
	label2 = label.new(bar_index, high, text="T3-Hull SE", style=label.style_labeldown, color=#FF0000)
	label.set_textcolor(label2, textcolor=color.white)
	
if WT_OB and Wave_Signals
	label2 = label.new(bar_index, high, text="WT SE", style=label.style_labeldown, color=#FF0000)
	label.set_textcolor(label2, textcolor=color.white)

if ShowTenkanKijunLables and crossover(Kijun, Tenkan)
	labelTenkan = label.new(bar_index, high, text="Kijun|Tenkan\nCx", style=label.style_labeldown, color=#FF0000)
	label.set_textcolor(labelTenkan, textcolor=color.white)


//barcolor(T3HullLE or T3HullLE2 ? #358600 : na, editable=false)
//barcolor(T3HullSE or T3HullSE2 ? #d00000 : na, editable=false)

// ***********************************************************************************
//------------------------------------ Angle of HMA --------------------------------//

HMA_for_angle = wma(2 * wma(close, 42 / 2) - wma(close, 42), round(sqrt(42)))
rad2degree = 180 / 3.141592653589793238462643  //pi 
ang = rad2degree * atan((HMA_for_angle[0] - HMA_for_angle[2]) / atr(10)/2)

upward = ang > ang[1] and (ang > 6 or ang < -6)
downward = ang < ang[1] and (ang > 6 or ang < -6)

//color_ang = upward ? color.lime : downward ? color.red : na
exit_position = ((hullma > T3) and downward) or ((hullma < T3) and upward)
color_ang = exit_position ? color.red : na

//long_stop = ((downward and upward[1])) ? true : false
//short_stop = ((upward and downward[1])) ? true : false
//plotshape(long_stop, title = "Exit Long", text = 'Exit Long')
//plotshape(short_stop, title = "Exit Short", text = 'Exit Short')

bgcolor(color_ang, transp=90, editable=false)

// ***********************************************************************************
//------------------------------------ Alerts --------------------------------------//
bullish_market = ((close > (EMA1 + (EMA1 * 0.002))) and (open > (EMA1 + (EMA1 * 0.002)))) and (((close > (EMA2 + (EMA2 * 0.002))) and (open > (EMA2 + (EMA2 * 0.002)))) or ((close > (ZEMA_200_12h + (ZEMA_200_12h * 0.002))) and (open > (ZEMA_200_12h + (ZEMA_200_12h * 0.002)))))

bearish_market = ((close < (EMA1 - (EMA1 * 0.002))) and (open < (EMA1 - (EMA1 * 0.002)))) and (((close < (EMA2 - (EMA2 * 0.002))) and (open < (EMA2 - (EMA2 * 0.002)))) or ((close < (ZEMA_200_12h - (ZEMA_200_12h * 0.002))) and (open < (ZEMA_200_12h - (ZEMA_200_12h * 0.002)))))

above_middle_line = open > y2 and close > y2
below_midle_line = open < y2 and close < y2

alertcondition(escgo_long and below_midle_line and bullish_market and above_cloud and LongConditions, title="AIO Long Entries", message="A Long Entry Confirmed")
alertcondition(escgo_short and above_middle_line and bearish_market and below_cloud and ShortConditions, title="AIO Short Entries", message="A Short Entry Confirmed")

alertcondition(T3HullLE, title="Hull|T3 Long Entry", message="Hull|T3 Long Entry")
alertcondition(T3HullSE, title="T3|Hull Short Entry", message="T3|Hull Short Entry")

alertcondition(sqzGoLong, title="SQZ-MOM Long Entry", message="SQZ-MOM Long Entry")
alertcondition(sqzGoShort, title="SQZ-MOM Short Entry", message="SQZ-MOM Short Entry")

alertcondition(WT_OB, title="WT Short Entry", message="WT Short Entry")
alertcondition(WT_OS, title="WT Long Entry", message="WT Long Entry")

alertcondition(MFIoverbought, title="MFI OB (Exit Long)", message="MFI OB (Exit Long)")
alertcondition(MFIoversold, title="MFI OS (Exit Short)", message="MFI OS (Exit Short)")

//alertcondition(posdivergence >= showlimit and not showhidden, title='Positive Divergence', message='Positive Divergence')
//alertcondition(negdivergence >= showlimit and not showhidden, title='Negative Divergence', message='Negative Divergence')
//alertcondition(hposdivergence >= showlimit and showhidden, title='Positive Hidden Divergence', message='Positive Hidden Divergence')
//alertcondition(hnegdivergence >= showlimit and showhidden, title='Negative Hidden Divergence', message='Negative Hidden Divergence')

alertcondition(crossover(ZEMA_200_6h, ZEMA_50_6h), title="ZEMA Cx 200|50 (30) SE", message="ZEMA Cx 200|50 (30) SE")
alertcondition(crossover(ZEMA_50_6h, ZEMA_200_6h), title="ZEMA Cx 50|200 (30) LE", message="ZEMA Cx 50|200 (30) LE")

alertcondition(crossover(ZEMA_200_12h, ZEMA_50_12h), title="ZEMA Cx 200|50  (4H) SE", message="ZEMA Cx 200|50 (4H) SE")
alertcondition(crossover(ZEMA_50_12h, ZEMA_200_12h), title="ZEMA Cx 50|200 (4H) LE", message="ZEMA Cx 50|200 (4H) LE")

alertcondition(crossover(ZEMA_200_d, ZEMA_50_d), title="ZEMA Cx 200|50 (D) SE", message="ZEMA Cx 200|50 (D) SE")
alertcondition(crossover(ZEMA_50_d, ZEMA_200_d), title="ZEMA Cx 50|200 (D) LE", message="ZEMA Cx 50|200 (D) LE")

alertcondition(crossover(Tenkan, Kijun), title="Tenkan|Kijun Long Entry", message="Tenkan|Kijun Long Entry")
alertcondition(crossover(Kijun, Tenkan), title="Kijun|Tenkan Short Entry", message="Kijun|Tenkan Short Entry")

alertcondition(cross(close, close[30]), title="Chikou Cx", message="Chikou has Crossed the Candles")