// ***********************************************************************************
//------------------------- Linear Regression -----------------------------//

LinRegSource = close
length = 100
offset = 0
LinRegDev   = 2.0		//Deviation
smoothing   = 1
mtf_val     = ""		//Resolution
line_thick  = 4			//S&R Thickness
signals     = "All"		//"Signals Display", options=["Recent", "All"]
goto        = 0			//"End At Bar Index"

data(x) => sma(security(syminfo.tickerid, mtf_val!="" ? mtf_val : timeframe.period, x), smoothing)

linreg = data(linreg(LinRegSource, length, offset))
linreg_p = data(linreg(LinRegSource, length, offset+1))
//plot(linreg, "Regression Line", linreg>linreg[1]?color.green:color.red, editable=false)

x = bar_index
slope = linreg - linreg_p
intercept = linreg - x*slope
deviationSum = 0.0
for i=0 to length-1
    deviationSum:= deviationSum + pow(LinRegSource[i]-(slope*(x-i)+intercept), 2)  
deviation = sqrt(deviationSum/(length))
x1 = x-length
x2 = x
y1 = slope*(x-length)+intercept
y2 = linreg

updating = goto <= 0 or x < goto

if updating
    line b = line.new(x1, y1, x2, y2, xloc.bar_index, extend.right, color.black, width=3)
	line.set_style(id=b, style=line.style_dashed)
    line.delete(b[1])
    line dp = line.new(x1, deviation*LinRegDev + y1, x2, deviation*LinRegDev + y2, xloc.bar_index, extend.right, color.red, width=3)
    line.set_style(id=dp, style=line.style_dashed)
    line.delete(dp[1])
    line dm = line.new(x1, -deviation*LinRegDev + y1, x2, -deviation*LinRegDev + y2, xloc.bar_index, extend.right, color.green, width=3)
    line.set_style(id=dm, style=line.style_dashed)
    line.delete(dm[1])

dm_current = -deviation*LinRegDev + y2
dp_current = deviation*LinRegDev + y2
buy = crossunder(close, dm_current)
sell = crossover(close, dp_current)

//plotshape(buy, "LinReg OS", shape.labelup, location.belowbar, color=#007f5f, text='LinReg OS', textcolor=color.white, show_last=signals=="All"?99999999:length, editable=false)
//plotshape(sell, "LinReg OB", shape.labeldown, location.abovebar, color=#d62828, text='LinReg OB', textcolor=color.white, show_last=signals=="All"?99999999:length, editable=false)
    
plot(x, "Bar Index", color.aqua, line_thick, plot.style_cross, display=display.none, editable=false)

// ***********************************************************************************
//------------------------- Ichimoku -----------------------------//
ShowIchiKumo = input(true, title="Show Kumo Cloud & Chikou Span")
ShowTenkanKijun = input(false, title="Show Tenkan Sen & Kijun Sen Lines")
ShowTenkanKijunLables = input(true, title="Show Tenkan|Kijun Cx Labels")

middleDonchian(Length) =>
    lower = lowest(Length)
    upper = highest(Length)
    avg(upper, lower)

conversionPeriods = 20		//deval=9
basePeriods = 60			//defval=26
laggingSpan2Periods = 120		//defval=52
displacement = 30			//defval=26

Tenkan = middleDonchian(conversionPeriods)
Kijun = middleDonchian(basePeriods)
xChikou = close
SenkouA = middleDonchian(laggingSpan2Periods)
SenkouB = (Tenkan[basePeriods] + Kijun[basePeriods]) / 2
plot(ShowTenkanKijun ? Tenkan : na, color=color.green, linewidth=3, title="Tenkan", editable=false)
plot(ShowTenkanKijun ? Kijun : na, color=color.red, linewidth=3, title="Kijun", editable=false)
plot(ShowIchiKumo ? xChikou : na, color=#ab47bc, linewidth=3, title="Chikou", offset=-displacement, editable=false)
A = plot(ShowIchiKumo ? SenkouA[displacement] : na, color=color.green, title="SenkouA", editable=false)
B = plot(ShowIchiKumo ? SenkouB : na, color=color.red, title="SenkouB", editable=false)
KumoCloudColor = SenkouA[displacement] > SenkouB ? color.green : color.red
KumoCloudFill = ShowIchiKumo ? 90 : 0
fill(A, B, KumoCloudColor, transp=KumoCloudFill, editable=false)

below_cloud = open < SenkouA[displacement] and open < SenkouB and close < SenkouA[displacement] and close < SenkouB
above_cloud = open > SenkouA[displacement] and open > SenkouB and close > SenkouA[displacement] and close > SenkouB

